{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "create-merge-request step result",
  "description": "Sidecar schema for the create-merge-request workflow step.",
  "type": "object",
  "required": ["schema_version", "step", "ticket", "completed_at", "commit_sha", "branch", "pushed", "url", "action", "platform", "skipped", "skip_reason"],
  "properties": {
    "schema_version": { "const": 1 },
    "step": { "const": "create-merge-request" },
    "ticket": { "type": "string", "description": "JIRA ticket ID as provided by the user (preserves original case)" },
    "completed_at": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp from `date -u +%Y-%m-%dT%H:%M:%SZ`" },
    "commit_sha": {
      "type": ["string", "null"],
      "description": "Git commit SHA (null when skipped)"
    },
    "branch": {
      "type": ["string", "null"],
      "description": "Branch name committed to (null when skipped)"
    },
    "pushed": { "type": "boolean", "description": "Whether the branch was pushed to the remote" },
    "url": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "MR/PR URL (null when skipped or not pushed). Consumed by orchestrator for final summary."
    },
    "action": {
      "type": "string",
      "enum": ["created", "found_existing", "skipped"],
      "description": "Action taken"
    },
    "platform": {
      "type": "string",
      "enum": ["github", "gitlab", "unknown"],
      "description": "Source platform"
    },
    "skipped": { "type": "boolean", "description": "Whether the step was skipped" },
    "skip_reason": {
      "type": ["string", "null"],
      "enum": ["draft", "no_changes", "no_files", "user_declined", "on_default_branch", "push_failed", "commit_failed", "create_failed", "unknown_platform", null],
      "description": "Reason when skipped, null otherwise"
    }
  },
  "additionalProperties": false
}
